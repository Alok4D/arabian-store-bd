// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  name      String   @default("Admin")
  email     String   @unique
  password  String
  image     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  image       String
  price       Decimal
  weight      String
  stock       Int
  shippingFee Decimal
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
}

model Order {
  id            String   @id @default(cuid())
  orderId       String   @unique
  customerName  String
  phone         String
  whatsapp      String?
  address       String
  note          String?
  quantity      Int
  subtotal      Decimal
  shippingFee   Decimal
  total         Decimal
  paymentMethod PaymentMethod @default(COD)
  status        OrderStatus   @default(PENDING)

  productId     String
  product       Product  @relation(fields: [productId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum PaymentMethod {
  COD
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKAGING
  SHIPPED
  DELIVERED
  CANCELLED
}
